/* Oriental Paper Theme */
.shop-page {
  min-height: 100vh;
  padding: 14rpx 24rpx 44rpx;
  box-sizing: border-box;
}

.shop-avatar {
  background: #ecdaba;
  color: #a46d3e;
  border-color: #c9ab86;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.asset-card {
  margin-top: 14rpx;
  background: linear-gradient(145deg, #f7ecs0 0%, #f1e0bf 100%);
  background: #fdfaf3;
  border: 3rpx solid #e0c8a1;
  border-radius: 28rpx;
  padding: 30rpx 36rpx;
  position: relative;
  box-shadow: 0 10rpx 24rpx rgba(125, 87, 43, 0.08), inset 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

.asset-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.asset-label {
  color: #8c6841;
  font-size: 26rpx;
  font-weight: 700;
}

.asset-tip {
  color: #ad8f6b;
  font-size: 20rpx;
}

.asset-body {
  margin-top: 12rpx;
  display: flex;
  align-items: baseline;
}

.asset-value {
  color: #dd7b15;
  font-size: 74rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 0 #eed9bf;
}

.payment-banner {
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  border: 2rpx solid rgba(194, 139, 74, 0.18);
  background: rgba(255, 248, 235, 0.88);
}

.payment-banner.enabled {
  border-color: rgba(103, 194, 58, 0.28);
  background: rgba(244, 252, 239, 0.94);
}

.payment-banner.disabled {
  border-color: rgba(188, 142, 85, 0.22);
}

.payment-banner-title {
  color: #7c5528;
  font-size: 24rpx;
  font-weight: 800;
}

.payment-banner-text {
  margin-top: 8rpx;
  color: #9a7c59;
  font-size: 22rpx;
  line-height: 1.5;
}

.category-tabs {
  margin-top: 32rpx;
  display: flex;
  gap: 40rpx;
  padding: 0 16rpx;
  border-bottom: 2rpx solid #e2cbaa;
}

.tab-item {
  position: relative;
  padding-bottom: 16rpx;
  font-size: 30rpx;
  color: #927555;
  font-weight: 600;
  transition: all 0.2s;
}

.tab-item.active {
  color: #c96a10;
  font-weight: 800;
}

.tab-line {
  position: absolute;
  bottom: -2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #e57c1f;
  border-radius: 4rpx;
}

.goods-grid {
  margin-top: 24rpx;
  display: grid;
  gap: 20rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  padding-bottom: 40rpx;
}

.goods-card {
  background: #fcf7eb;
  border: 2rpx solid #e1ceac;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(135, 98, 54, 0.05);
  display: flex;
  flex-direction: column;
  min-width: 0;
  box-sizing: border-box;
}

.goods-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-badge {
  background: #ebd2aa;
  color: #855d28;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 700;
}

.goods-price {
  color: #dd7b15;
  display: flex;
  align-items: baseline;
}

.price-num {
  font-size: 36rpx;
  font-weight: 900;
}

.goods-visual {
  margin-top: 16rpx;
  height: 160rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 8rpx rgba(255,255,255,0.6), 0 4rpx 10rpx rgba(0,0,0,0.05);
  position: relative;
  overflow: hidden;
  background: #f1ebd8;
}

.visual-placeholder {
  font-size: 72rpx;
  z-index: 2;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.15));
}

.pet-cover,
.skin-cover {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 16rpx;
}

.goods-visual.skin-photo {
  width: 280rpx;
  height: 280rpx;
  align-self: center;
  background: #efe5d3;
  border: 2rpx solid #dbc7a1;
}

.goods-visual.ring-photo {
  width: 280rpx;
  height: 280rpx;
  align-self: center;
  background:
    radial-gradient(circle at 50% 35%, rgba(255, 241, 206, 0.96) 0%, rgba(244, 230, 204, 0.92) 38%, rgba(235, 221, 195, 0.98) 100%);
  border: 2rpx solid #dbc7a1;
}

/* Pets Backgrounds */
.goods-visual.pet-photo {
  height: 330rpx;
  background: #efe5d3;
  border: 2rpx solid #dbc7a1;
}

.ring-preview-shell {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ring-preview-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #f7edd8;
  box-shadow: 0 6rpx 16rpx rgba(132, 90, 41, 0.16);
}

.ring-preview-overlay {
  position: absolute;
  inset: -26rpx;
  width: auto;
  height: auto;
}

.goods-info {
  margin-top: 16rpx;
  flex: 1;
}

.goods-name {
  color: #4a2d1a;
  font-size: 28rpx;
  font-weight: 800;
}

.goods-desc {
  margin-top: 6rpx;
  color: #8a7051;
  font-size: 22rpx;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-action-btn {
  margin-top: 20rpx;
  width: 100%;
  height: 60rpx;
  border-radius: 999rpx;
  padding: 0 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fdf9f1;
  background: linear-gradient(135deg, #f4b24a, #e57c1f);
  box-shadow: 0 4rpx 12rpx rgba(179, 101, 24, 0.2);
  box-sizing: border-box;
  white-space: nowrap;
}

.goods-action-btn::after {
  border: none;
}

.goods-action-btn.equip {
  background: #d1ab64;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(209, 171, 100, 0.2);
}

.goods-action-btn.disabled {
  opacity: 0.6;
  background: #d2c4b0;
  box-shadow: none;
  color: #fff;
}

.cursor-hover:active {
  transform: scale(0.97);
  transition: transform 0.1s;
}
