<view class="paper-bg shop-page">
  <image class="global-bg-image" src="https://xcx.ukb88.com/assets/bg/bg.png" mode="scaleToFill"></image>

  <view class="app-header" style="padding-top: {{ nav.statusBarHeight }}px; padding-right: {{ nav.capsuleSpace }}px;">
    <view class="app-user">
      <image wx:if="{{avatarUrl}}" class="app-user-avatar shop-avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
      <image wx:else class="app-user-avatar shop-avatar" src="{{defaultAvatar}}" mode="aspectFill"></image>
      <text class="app-user-name">装备商城</text>
    </view>
    <view class="app-header-right">
      <view class="app-status-pill">
        <text class="app-status-text">装备商城</text>
      </view>
      <view class="app-gear" bindtap="onBack" hover-class="clickable-hover">✦</view>
    </view>
  </view>

  <view class="page-content">
    <view class="asset-card">
      <view class="asset-header">
        <text class="asset-label">当前账户余额</text>
        <text class="asset-tip">购买后可在对局页展示效果</text>
      </view>
      <view class="asset-body">
        <text class="asset-value">{{ balanceText }}</text>
      </view>
      <view class="payment-banner {{ payEnabled ? 'enabled' : 'disabled' }}">
        <view class="payment-banner-title">{{ payStatusText }}</view>
        <view class="payment-banner-text">{{ payHintText }}</view>
      </view>
    </view>

    <view class="category-tabs">
      <view
        wx:for="{{ categories }}"
        wx:key="key"
        class="tab-item {{ activeCategory == item.key ? 'active' : '' }}"
        data-category="{{ item.key }}"
        bindtap="onSwitchCategory"
        hover-class="clickable-hover"
      >
        {{ item.label }}
        <view class="tab-line" wx:if="{{ activeCategory == item.key }}"></view>
      </view>
    </view>

    <view class="goods-grid">
      <view wx:for="{{ goods }}" wx:key="id" class="goods-card" hover-class="clickable-hover">
        <view class="goods-head">
          <view class="goods-badge">{{ item.category == 'skin' ? item.rarityLabel : item.category == 'ring' ? '头像光环' : '灵宠' }}</view>
          <view class="goods-price">
            <text class="price-num">{{ item.priceText }}</text>
          </view>
        </view>
        
        <view class="goods-visual {{ item.category == 'skin' ? 'skin-photo' : item.category == 'ring' ? 'ring-photo' : 'pet-photo' }}">
          <view wx:if="{{ item.category == 'ring' }}" class="ring-preview-shell">
            <image class="ring-preview-avatar" src="{{ avatarUrl || defaultAvatar }}" mode="aspectFill"></image>
            <image class="ring-preview-overlay" src="{{ item.ringImage }}" mode="aspectFit"></image>
          </view>
          <image
            wx:if="{{ item.category == 'pet' && item.petImage }}"
            class="pet-cover"
            src="{{ item.petImage }}"
            mode="aspectFit"
          ></image>
          <image
            wx:elif="{{ item.category == 'skin' && item.skinImage }}"
            class="skin-cover"
            src="{{ item.skinImage }}"
            mode="aspectFit"
          ></image>
          <view wx:elif="{{ item.category != 'ring' }}" class="visual-placeholder">
            {{ item.category == 'skin' ? item.skinIcon : item.petIcon }}
          </view>
        </view>

        <view class="goods-info">
          <view class="goods-name">{{ item.name }}</view>
          <view class="goods-desc">{{ item.description }}</view>
        </view>

        <view
          class="goods-action-btn {{ item.status.action == 'buy' ? 'buy' : 'equip' }} {{ item.status.disabled ? 'disabled' : '' }}"
          data-category="{{ item.category }}"
          data-item-id="{{ item.id }}"
          data-action="{{ item.status.disabled ? '' : item.status.action }}"
          bindtap="onTapAction"
          hover-class="btn-hover"
        >
          {{ item.status.text }}
        </view>
      </view>
    </view>
  </view>
</view>
