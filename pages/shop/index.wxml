<view class="paper-bg shop-page">
  <image class="global-bg-image" src="/assets/bg/bg.png" mode="scaleToFill"></image>

  <view class="app-header" style="padding-top: {{ nav.statusBarHeight }}px; padding-right: {{ nav.capsuleSpace }}px;">
    <view class="app-user">
      <view class="app-user-avatar shop-avatar">🛍</view>
      <text class="app-user-name">旅行商城</text>
    </view>
    <view class="app-header-right">
      <view class="app-status-pill">
        <text class="app-status-text">装备中心</text>
      </view>
      <view class="app-gear" bindtap="onBack">✦</view>
    </view>
  </view>

  <view class="page-content">
    <view class="card coins-card">
      <view class="coins-label">当前幸运金币</view>
      <view class="coins-value">{{ coins }}</view>
      <view class="coins-tip">购买后可在对局页展示皮肤与宠物效果</view>
    </view>

    <view class="category-row">
      <view
        wx:for="{{ categories }}"
        wx:key="key"
        class="category-chip {{ activeCategory === item.key ? 'active' : '' }}"
        data-category="{{ item.key }}"
        bindtap="onSwitchCategory"
      >
        {{ item.label }}
      </view>
    </view>

    <view class="goods-list">
      <view wx:for="{{ goods }}" wx:key="id" class="card goods-card">
        <view class="goods-top">
          <view class="goods-badge" style="background: {{ item.accent }};">{{ item.category === 'skin' ? '皮肤' : '宠物' }}</view>
          <view class="goods-price">{{ item.price === 0 ? '默认拥有' : item.price + ' 金币' }}</view>
        </view>
        <view class="goods-name">{{ item.name }}</view>
        <view class="goods-preview" style="color: {{ item.accent }};">
          {{ item.category === 'skin' ? '◉ 头像框效果' : item.petIcon + ' ' + item.petLabel }}
        </view>
        <view class="goods-desc">{{ item.description }}</view>
        <button
          class="goods-action {{ item.status.action === 'buy' ? 'buy' : 'equip' }}"
          disabled="{{ item.status.disabled }}"
          data-category="{{ item.category }}"
          data-item-id="{{ item.id }}"
          data-action="{{ item.status.action }}"
          bindtap="onTapAction"
        >
          {{ item.status.text }}
        </button>
      </view>
    </view>
  </view>
</view>
