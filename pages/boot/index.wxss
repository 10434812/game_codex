.boot-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  overflow: hidden;
  background: #f6ebd1;
}

.boot-content {
  position: fixed;
  inset: 0;
  z-index: 1;
  box-sizing: border-box;
  padding: 0;
}

.boot-stage {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 0;
}

.boot-art {
  position: absolute;
  display: block;
}

.boot-art-glow {
  position: absolute;
  left: 50%;
  top: 60%;
  width: 64%;
  height: 18%;
  transform: translateX(-50%);
  background: radial-gradient(circle, rgba(255, 231, 170, 0.34) 0%, rgba(255, 231, 170, 0) 72%);
  pointer-events: none;
}

.boot-progress-shell {
  position: absolute;
  overflow: hidden;
  border-radius: 999rpx;
  pointer-events: none;
  background: transparent;
}

.boot-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #e85c21 0%, #f29f39 44%, #ffd867 100%);
  box-shadow: 0 0 18rpx rgba(255, 195, 70, 0.72);
  transition: width 260ms cubic-bezier(0.22, 1, 0.36, 1);
}
