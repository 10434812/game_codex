<view class="paper-bg income-page">
  <image class="global-bg-image" src="/assets/bg/bg.png" mode="scaleToFill"></image>

  <view class="app-header" style="padding-top: {{nav.statusBarHeight}}px; padding-right: {{nav.capsuleSpace}}px;">
    <view class="app-user">
      <view class="app-user-avatar">¥</view>
      <text class="app-user-name">资金明细</text>
    </view>
    <view class="app-header-right">
      <view class="app-status-pill">
        <text class="app-status-text">历史记录</text>
      </view>
      <view class="app-gear" bindtap="onBack">←</view>
    </view>
  </view>

  <view class="page-content">
    <view class="card summary-card">
      <view class="summary-main">{{balanceText}}</view>
      <view class="summary-sub">统一资金账户</view>
    </view>

    <view class="list-head">完整资金明细</view>

    <view wx:if="{{records.length}}" class="record-list">
      <view wx:for="{{records}}" wx:key="id" class="record-item">
        <view class="record-row">
          <text class="record-stage">{{item.typeText}}</text>
          <text class="record-income">{{item.amountText}}</text>
        </view>
        <view class="record-row sub">
          <text>{{item.title}}</text>
          <text>{{item.balanceText}}</text>
        </view>
        <view class="record-row sub">
          <text>账户流水</text>
          <text>{{item.timeText}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">暂无资金记录，先开始一局吧</view>
  </view>
</view>
