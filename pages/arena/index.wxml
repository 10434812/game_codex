<view class="paper-bg arena-page">
  <image class="global-bg-image" src="/assets/bg/gamebg.png" mode="scaleToFill"></image>
  <view class="app-header" style="padding-top: {{ nav.statusBarHeight }}px; padding-right: {{ nav.capsuleSpace }}px;">
    <view class="app-user" bindtap="onTapProfile">
      <image wx:if="{{userProfile.avatarUrl}}" class="app-user-avatar" src="{{userProfile.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="app-user-avatar"></view>
      <text class="app-user-name">{{userProfile.nickName}}</text>
    </view>
    <view class="app-header-right">
      <view class="app-status-pill">
        <text class="app-status-dot">●</text>
        <text class="app-status-text">{{modeText}}</text>
      </view>
      <view class="app-gear">⚙</view>
    </view>
  </view>

  <view class="page-content">
    <view class="timer card">
      <view class="time">{{timeText}}</view>
      <view class="hint">{{actionHintText || hintText}}</view>
    </view>

    <view class="board">
      <view class="link-layer">
        <view class="link team-link" wx:for="{{ teamLinks }}" wx:key="id" style="{{ item.style }}"></view>
        <view class="link invite-link" wx:if="{{ inviteLink }}" style="{{ inviteLink.style }}"></view>
        <view class="link success-link" wx:if="{{ successLink }}" style="{{ successLink.style }}"></view>
      </view>

      <view class="fortune-bag-wrap" wx:if="{{ fortuneBag }}" style="left: {{ fortuneBag.x }}rpx; top: {{ fortuneBag.y }}rpx;" bindtap="onTapFortuneBag">
        <view class="fortune-bag-label">{{ activePosition ? '卖出' : '买入' }}</view>
        <view class="fortune-bag-countdown">{{ fortuneBagCountdownText }}</view>
        <view class="fortune-bag-shell">
          <image class="fortune-bag-image" src="{{ fortuneBag.asset }}" mode="aspectFit"></image>
        </view>
      </view>

      <view class="team-success-toast" wx:if="{{ successToast }}" style="left: {{ successToast.x }}rpx; top: {{ successToast.y }}rpx;">
        {{ successToast.text }}
      </view>

      <view class="player-node {{ item.isSelf ? 'self-node' : '' }}" wx:for="{{ players }}" wx:key="id" style="left: {{ item.x }}rpx; top: {{ item.y }}rpx;" data-player-id="{{ item.id }}" bindtap="onPlayerTap">
        <view class="avatar-shell {{ item.isSelf ? 'self-avatar-shell' : '' }} {{ item.skinClass }}">
          <image class="avatar" src="{{ item.avatar || '/assets/bg/avatars/avatar_01.png' }}" mode="aspectFill"></image>
        </view>
        <view
          class="pet-follower"
          wx:if="{{ item.isSelf && item.petLabel }}"
        >
          <view class="pet-avatar-shell" style="background: linear-gradient(145deg, #fff8ec 0%, {{ item.petAccent || '#d8a062' }} 100%);">
            <image wx:if="{{ item.petImage }}" class="pet-avatar" src="{{ item.petImage }}" mode="aspectFill"></image>
            <text wx:else class="pet-emoji">{{ item.petIcon }}</text>
          </view>
        </view>
        <view class="score-visible-tag" wx:if="{{ item.showScore && !item.isSelf }}">
          <view class="score-visible-blood">
            <view class="score-visible-blood-fill" style="width: {{ item.revealHpPercent }}%;"></view>
          </view>
        </view>
        <view class="emote-bubble emote-{{ item.chatPos || 'upper-center' }}" wx:if="{{ item.emoteText }}">{{ item.emoteText }}</view>
        <view class="self-tag" wx:if="{{ item.isSelf }}">我</view>
      </view>

      <view class="player-name-layer">
        <view class="player-label-anchor" wx:for="{{ players }}" wx:key="id" style="left: {{ item.x }}rpx; top: {{ item.y }}rpx;">
          <view class="node-name name-{{ item.namePos || 'center' }} {{ item.isSelf ? 'self-node-name' : '' }}">{{ item.scoreLabel }}</view>
        </view>
      </view>
    </view>

    <view class="invest-panel fortune-panel" wx:if="{{ fortunePanelVisible }}">
      <view class="invest-head">
        <text class="invest-type">{{ activePosition ? '卖出窗口' : activeOpportunity.category }}</text>
        <text class="invest-risk">{{ activePosition ? activePosition.riskText : activeOpportunity.riskText }}</text>
      </view>
      <view class="invest-title">{{ activePosition ? activePosition.name : activeOpportunity.name }}</view>
      <view wx:if="{{ activePosition }}">
        <view class="invest-line invest-highlight">持仓成本：{{ activePosition.cost }}</view>
        <view class="invest-line invest-highlight">持有时间：{{ activePositionHoldText }}</view>
        <view class="invest-line">再次弹出会提示卖出当前持仓</view>
      </view>
      <view wx:else>
        <view class="invest-line invest-highlight">投入成本：{{ activeOpportunity.cost }}</view>
        <view class="invest-line invest-highlight">预计波动：{{ activeOpportunity.floatRangeText }}</view>
        <view class="invest-line invest-summary">{{ activeOpportunity.summary }}</view>
      </view>
      <view class="invest-actions">
        <button class="invest-btn ghost" bindtap="onCloseOpportunity">先放弃</button>
        <button wx:if="{{ !activePosition }}" class="invest-btn primary-btn" bindtap="onConfirmOpportunity">立即买入</button>
        <button wx:else class="invest-btn primary-btn" bindtap="onSellPosition">确认卖出</button>
      </view>
    </view>

    <view class="quick-emote-panel" wx:if="{{ emotePanelVisible }}" style="bottom: {{ messageCardCollapsed ? 388 : 484 }}rpx;">
      <view
        class="quick-emote-item"
        wx:for="{{ quickEmotes }}"
        wx:key="key"
        data-key="{{ item.key }}"
        bindtap="onSendQuickEmote"
      >
        {{ item.label }}
      </view>
    </view>

    <view class="message-reply-card {{ messageCardCollapsed ? 'collapsed' : '' }}">
      <view class="message-reply-head" bindtap="onToggleMessageCard">
        <view class="message-reply-title">消息回复</view>
        <view class="message-reply-toggle">{{ messageCardCollapsed ? '展开' : '收起' }}</view>
      </view>
      <scroll-view wx:if="{{ !messageCardCollapsed }}" class="message-reply-list" scroll-y="{{true}}">
        <view wx:if="{{!chatMessages.length}}" class="message-empty">点击右侧按钮发送快捷回复</view>
        <view wx:for="{{ chatMessages }}" wx:key="id" class="message-item {{ item.isSelf ? 'self' : '' }}">
          <text class="message-name">{{item.sender}}：</text>
          <text class="message-text">{{item.text}}</text>
        </view>
      </scroll-view>
      <view class="quick-reply-row">
        <view
          class="quick-reply-chip"
          wx:for="{{quickReplyOptions}}"
          wx:key="key"
          data-key="{{ item.key }}"
          bindtap="onSendQuickEmote"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="shop-entry" style="bottom: {{ messageCardCollapsed ? 286 : 382 }}rpx;" bindtap="onTapShop">
      <text class="shop-entry-icon">✦</text>
      <text>商城</text>
    </view>

    <view class="quick-emote" style="bottom: {{ messageCardCollapsed ? 286 : 382 }}rpx;" bindtap="onToggleEmotePanel">☺</view>
  </view>

  <view class="bottom-nav">
    <view wx:for="{{ tabs }}" wx:key="key" class="nav-item {{ activeTab === item.key ? 'active' : '' }}" data-page="{{ item.page }}" bindtap="switchTab">
      <view class="nav-dot"><image class="nav-icon" src="{{activeTab===item.key ? item.iconActive : item.icon}}" mode="aspectFit"></image></view>
      <text>{{ item.label }}</text>
    </view>
  </view>
</view>
