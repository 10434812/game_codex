.room-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 34rpx;
  background: transparent;
}

.page-content {
  padding-bottom: 184rpx;
}

.room-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.user {
  font-size: 52rpx;
  font-weight: 800;
  color: #302014;
}

.room-hero {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.room-heading {
  flex: 1 1 auto;
  min-width: 0;
}

.big-title {
  max-width: 100%;
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 900;
  color: #2f1c12;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.room-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #7f5a32;
  font-weight: 600;
}

.tags {
  flex: 0 0 auto;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 8rpx;
}

.tag {
  background: #cfb383;
  color: #4f361f;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
  padding: 8rpx 14rpx;
  white-space: nowrap;
}

.slot-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.slot {
  min-height: 178rpx;
  border-radius: 14rpx;
  border: 3rpx solid #d4b98a;
  background: rgba(255, 248, 231, 0.88);
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.slot.empty {
  border-style: dashed;
  background: rgba(251, 241, 219, 0.65);
}

.slot .avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  border: 4rpx solid #d2ad67;
  background: linear-gradient(145deg, #4d6478, #1e3549);
}

.plus {
  width: 78rpx;
  height: 78rpx;
  border: 3rpx solid #c5a26a;
  border-radius: 50%;
  color: #9c723d;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.slot-name {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #4f3620;
  font-weight: 700;
}

.slot-state {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #90724b;
}

.star {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  color: #dbb756;
  font-size: 24rpx;
}

.voice-box {
  margin-top: 24rpx;
  border-radius: 22rpx;
  padding: 18rpx 24rpx 20rpx;
  background: rgba(255, 248, 234, 0.93);
  border: 2rpx solid rgba(205, 171, 114, 0.6);
  box-shadow: 0 8rpx 20rpx rgba(123, 87, 41, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
}

.voice-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voice-title {
  color: #6b4a2d;
  font-size: 26rpx;
  font-weight: 700;
}

.percent {
  font-size: 42rpx;
  line-height: 1;
  color: #dd7b15;
  font-weight: 900;
  text-shadow: 0 2rpx 0 #eed9bf;
}

.track {
  margin-top: 12rpx;
  background: rgba(220, 198, 162, 0.5);
  border-radius: 999rpx;
  height: 16rpx;
  padding: 3rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(197, 166, 118, 0.4);
}

.bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f4b24a, #e57c1f);
  box-shadow: 0 2rpx 8rpx rgba(171, 58, 52, 0.3);
}

.bottom-actions {
  margin-top: 32rpx;
  padding-bottom: 8rpx;
  width: 100%;
}

.secondary-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  width: 100%;
}

.invite-btn {
  flex: 1 1 0;
  width: auto !important;
  max-width: none !important;
  min-width: 0;
  margin: 0;
  height: 92rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(224, 180, 111, 0.82);
  box-shadow: 0 6rpx 14rpx rgba(122, 90, 48, 0.14), inset 0 2rpx 0 rgba(255, 255, 255, 0.82);
  background: rgba(255, 253, 246, 0.96);
  color: #c96a10;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-btn {
  width: 100% !important;
  max-width: none !important;
  min-width: 0;
  margin: 0 0 16rpx;
  border-radius: 999rpx;
  height: 100rpx;
  border: 3rpx solid rgba(204, 120, 22, 0.55);
  box-shadow: 0 10rpx 24rpx rgba(179, 101, 24, 0.3);
  font-size: 40rpx;
  font-weight: 700;
  color: #fff7e5;
  background: linear-gradient(135deg, #f5bc60, #e57c1f);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ready-btn {
  flex: 1 1 0;
  width: auto !important;
  max-width: none !important;
  min-width: 0;
  margin: 0;
  border-radius: 999rpx;
  height: 92rpx;
  border: 3rpx solid rgba(224, 180, 111, 0.82);
  box-shadow: 0 6rpx 14rpx rgba(122, 90, 48, 0.14), inset 0 2rpx 0 rgba(255, 255, 255, 0.82);
  font-size: 32rpx;
  font-weight: 700;
  background: rgba(255, 253, 246, 0.96);
  color: #c96a10;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-btn::after,
.start-btn::after,
.ready-btn::after {
  border: 0;
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 34rpx;
  line-height: 1;
}
