.room-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 34rpx;
  background: transparent;
}

.page-content {
  padding-bottom: 184rpx;
}

.room-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.user {
  font-size: 52rpx;
  font-weight: 800;
  color: #302014;
}

.room-hero {
  margin-top: 16rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
  animation: room-hero-in 0.52s ease-out both;
}

.room-heading {
  flex: 1 1 auto;
  min-width: 0;
}

.big-title {
  max-width: 100%;
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 900;
  color: #2f1c12;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  animation: room-title-glow 3s ease-in-out infinite;
}

.room-hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.4;
  color: #7f5a32;
  font-weight: 600;
}

.tags {
  flex: 0 0 auto;
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 8rpx;
}

.tag {
  background: #cfb383;
  color: #4f361f;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
  padding: 8rpx 14rpx;
  white-space: nowrap;
  animation: room-tag-pop 0.36s ease-out both;
}

.tag:nth-child(2) {
  animation-delay: 0.08s;
}

.slot-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.slot {
  min-height: 178rpx;
  border-radius: 14rpx;
  border: 3rpx solid #d4b98a;
  background: rgba(255, 248, 231, 0.88);
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  animation: slot-rise 0.48s cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.slot:nth-child(2) { animation-delay: 0.04s; }
.slot:nth-child(3) { animation-delay: 0.08s; }
.slot:nth-child(4) { animation-delay: 0.12s; }
.slot:nth-child(5) { animation-delay: 0.16s; }
.slot:nth-child(6) { animation-delay: 0.2s; }
.slot:nth-child(7) { animation-delay: 0.24s; }
.slot:nth-child(8) { animation-delay: 0.28s; }
.slot:nth-child(9) { animation-delay: 0.32s; }
.slot:nth-child(10) { animation-delay: 0.36s; }

.slot.empty {
  border-style: dashed;
  background: rgba(251, 241, 219, 0.65);
  animation-name: slot-rise, empty-slot-breathe;
  animation-duration: 0.48s, 2.4s;
  animation-timing-function: cubic-bezier(0.2, 0.8, 0.2, 1), ease-in-out;
  animation-fill-mode: both, none;
  animation-iteration-count: 1, infinite;
}

.slot .avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  border: 4rpx solid #d2ad67;
  background: linear-gradient(145deg, #4d6478, #1e3549);
  animation: avatar-settle 0.5s ease-out both;
}

.plus {
  width: 78rpx;
  height: 78rpx;
  border: 3rpx solid #c5a26a;
  border-radius: 50%;
  color: #9c723d;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: plus-pulse 1.8s ease-in-out infinite;
}

.slot-name {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #4f3620;
  font-weight: 700;
}

.slot-state {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #90724b;
}

.star {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  color: #dbb756;
  font-size: 24rpx;
}

.voice-box {
  margin-top: 24rpx;
  border-radius: 22rpx;
  padding: 18rpx 24rpx 20rpx;
  background: rgba(255, 248, 234, 0.93);
  border: 2rpx solid rgba(205, 171, 114, 0.6);
  box-shadow: 0 8rpx 20rpx rgba(123, 87, 41, 0.12), inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
}

.voice-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voice-title {
  color: #6b4a2d;
  font-size: 26rpx;
  font-weight: 700;
}

.percent {
  font-size: 42rpx;
  line-height: 1;
  color: #dd7b15;
  font-weight: 900;
  text-shadow: 0 2rpx 0 #eed9bf;
}

.track {
  margin-top: 12rpx;
  background: rgba(220, 198, 162, 0.5);
  border-radius: 999rpx;
  height: 16rpx;
  padding: 3rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(197, 166, 118, 0.4);
}

.bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f4b24a, #e57c1f);
  box-shadow: 0 2rpx 8rpx rgba(171, 58, 52, 0.3);
  transition: width 0.35s ease;
  animation: activity-flow 1.4s linear infinite;
  background-size: 180% 100%;
}

.bottom-actions {
  margin-top: 32rpx;
  padding-bottom: 8rpx;
  width: 100%;
}

.secondary-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  width: 100%;
}

.invite-btn {
  flex: 1 1 0;
  width: auto !important;
  max-width: none !important;
  min-width: 0;
  margin: 0;
  height: 92rpx;
  border-radius: 999rpx;
  border: 3rpx solid rgba(224, 180, 111, 0.82);
  box-shadow: 0 6rpx 14rpx rgba(122, 90, 48, 0.14), inset 0 2rpx 0 rgba(255, 255, 255, 0.82);
  background: rgba(255, 253, 246, 0.96);
  color: #c96a10;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-btn {
  width: 560rpx !important;
  max-width: calc(100% - 80rpx) !important;
  min-width: 0;
  margin: 0 auto 18rpx;
  border-radius: 999rpx;
  height: 92rpx;
  border: 3rpx solid rgba(204, 120, 22, 0.55);
  box-shadow: 0 10rpx 24rpx rgba(179, 101, 24, 0.3);
  font-size: 36rpx;
  font-weight: 700;
  color: #fff7e5;
  background: linear-gradient(135deg, #f5bc60, #e57c1f);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: ready-breathe 2.2s ease-in-out infinite;
}

.ready-btn {
  flex: 1 1 0;
  width: auto !important;
  max-width: none !important;
  min-width: 0;
  margin: 0;
  border-radius: 999rpx;
  height: 92rpx;
  border: 3rpx solid rgba(224, 180, 111, 0.82);
  box-shadow: 0 6rpx 14rpx rgba(122, 90, 48, 0.14), inset 0 2rpx 0 rgba(255, 255, 255, 0.82);
  font-size: 32rpx;
  font-weight: 700;
  background: rgba(255, 253, 246, 0.96);
  color: #c96a10;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-btn::after,
.start-btn::after,
.ready-btn::after {
  border: 0;
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 34rpx;
  line-height: 1;
}

@keyframes room-hero-in {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes room-title-glow {
  0%, 100% {
    text-shadow: 0 3rpx 0 rgba(255, 242, 205, 0.72);
  }
  50% {
    text-shadow: 0 3rpx 0 rgba(255, 242, 205, 0.95), 0 12rpx 22rpx rgba(218, 125, 22, 0.24);
  }
}

@keyframes room-tag-pop {
  from {
    opacity: 0;
    transform: scale(0.86);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes slot-rise {
  from {
    opacity: 0;
    transform: translateY(26rpx) scale(0.94);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes empty-slot-breathe {
  0%, 100% {
    border-color: #d4b98a;
    box-shadow: none;
  }
  50% {
    border-color: #e3a94b;
    box-shadow: 0 8rpx 18rpx rgba(190, 127, 36, 0.14);
  }
}

@keyframes avatar-settle {
  from {
    transform: scale(0.78) rotate(-8deg);
    opacity: 0;
  }
  to {
    transform: scale(1) rotate(0);
    opacity: 1;
  }
}

@keyframes plus-pulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.72;
  }
  50% {
    transform: scale(1.08);
    opacity: 1;
  }
}

@keyframes activity-flow {
  from {
    background-position: 0 0;
  }
  to {
    background-position: 180% 0;
  }
}

@keyframes ready-breathe {
  0%, 100% {
    transform: translateY(0);
    box-shadow: 0 10rpx 24rpx rgba(179, 101, 24, 0.3);
  }
  50% {
    transform: translateY(-4rpx);
    box-shadow: 0 16rpx 30rpx rgba(179, 101, 24, 0.38);
  }
}
