.room-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 34rpx;
  background: transparent;
}

.room-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-sizing: border-box;
}

.user {
  font-size: 52rpx;
  font-weight: 800;
  color: #302014;
}

.big-title {
  margin-top: 26rpx;
  font-size: 88rpx;
  line-height: 1;
  font-weight: 900;
  color: #2f1c12;
}

.tags {
  margin-top: 12rpx;
  display: flex;
  gap: 14rpx;
}

.tag {
  background: #cfb383;
  color: #4f361f;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
}

.slot-grid {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.slot {
  min-height: 178rpx;
  border-radius: 14rpx;
  border: 3rpx solid #d4b98a;
  background: rgba(255, 248, 231, 0.88);
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.slot.empty {
  border-style: dashed;
  background: rgba(251, 241, 219, 0.65);
}

.slot .avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  border: 4rpx solid #d2ad67;
  background: linear-gradient(145deg, #4d6478, #1e3549);
}

.plus {
  width: 78rpx;
  height: 78rpx;
  border: 3rpx solid #c5a26a;
  border-radius: 50%;
  color: #9c723d;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.slot-name {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #4f3620;
  font-weight: 700;
}

.slot-state {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #90724b;
}

.star {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  color: #dbb756;
  font-size: 24rpx;
}

.voice-box {
  margin-top: 30rpx;
  border-radius: 16rpx;
  padding: 18rpx 24rpx 20rpx;
  background: linear-gradient(160deg, #201109, #412312);
  border: 3rpx solid #9f6f30;
  box-shadow: inset 0 0 0 2rpx rgba(219, 170, 89, 0.45);
}

.voice-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.voice-title {
  color: #d9a145;
  font-size: 34rpx;
  font-weight: 700;
}

.percent {
  font-size: 54rpx;
  line-height: 1;
  color: #f0ba2f;
  font-weight: 800;
}

.track {
  margin-top: 18rpx;
  background: linear-gradient(90deg, #7b4c1f, #4b2d18);
  border-radius: 999rpx;
  height: 24rpx;
  padding: 2rpx;
  box-sizing: border-box;
}

.bar {
  width: 88%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #fbc20f, #f5ad00);
}

.bottom-actions {
  margin-top: 32rpx;
  padding-bottom: 8rpx;
  width: 100%;
}

.invite-btn {
  width: 100% !important;
  max-width: none !important;
  min-width: 0;
  margin: 0 auto;
  height: 96rpx;
  border-radius: 999rpx;
  border: 3rpx solid #cc8a45;
  box-shadow: inset 0 0 0 2rpx rgba(239, 178, 99, 0.35);
  background: linear-gradient(180deg, #cc3b31, #b42b24);
  color: #f3ce8d;
  font-size: 46rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-btn {
  width: 100% !important;
  max-width: none !important;
  min-width: 0;
  margin: 20rpx auto 0;
  border-radius: 999rpx;
  height: 96rpx;
  border: 3rpx solid #d8ac61;
  box-shadow: inset 0 0 0 2rpx rgba(251, 225, 166, 0.45);
  font-size: 48rpx;
  font-weight: 700;
  color: #4a210f;
  background: linear-gradient(180deg, #f4cf88, #e8bc67);
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-btn::after,
.start-btn::after {
  border: 0;
}

.btn-icon {
  margin-right: 14rpx;
  font-size: 40rpx;
  line-height: 1;
}
