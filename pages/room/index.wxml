<view class="paper-bg room-page">
  <image class="global-bg-image" src="https://xcx.ukb88.com/assets/bg/roombg.png" mode="scaleToFill"></image>
  <view class="app-header" style="padding-top: {{nav.statusBarHeight}}px; padding-right: {{nav.capsuleSpace}}px;">
    <view class="app-user" bindtap="onTapProfile" hover-class="clickable-hover">
      <image wx:if="{{userProfile.avatarUrl}}" class="app-user-avatar" src="{{userProfile.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="app-user-avatar"></view>
      <text class="app-user-name">{{userProfile.nickName}}</text>
    </view>
    <view class="app-header-right">
      <view class="app-status-pill">
        <text class="app-status-dot">●</text>
        <text class="app-status-text">{{modeText}}</text>
      </view>
      <view class="app-gear" hover-class="clickable-hover">⚙</view>
    </view>
  </view>

  <view class="page-content">
    <view class="big-title">{{stageName}}</view>
    <view class="room-hint">{{roomHintText}}</view>
    <view class="tags">
      <text class="tag">房间 #{{roomId}}</text>
      <text class="tag">{{modeText}}</text>
    </view>

    <view class="slot-grid">
      <view class="slot {{item.filled?'filled':'empty'}}" wx:for="{{slots}}" wx:key="index">
        <image class="avatar" wx:if="{{item.filled}}" src="{{item.avatar}}" mode="aspectFill"></image>
        <view class="plus" wx:else>＋</view>
        <view class="slot-name">{{item.name}}</view>
        <view class="slot-state" wx:if="{{item.state}}">• {{item.state}}</view>
        <view class="star" wx:if="{{item.star}}">★</view>
      </view>
    </view>

    <view class="voice-box">
      <view class="voice-line">
        <text class="voice-title">房间活跃度</text>
        <text class="percent">{{activePercent}}%</text>
      </view>
      <view class="track"><view class="bar" style="width: {{activePercent}}%;"></view></view>
    </view>

    <view class="bottom-actions">
      <button class="start-btn" bindtap="start" disabled="{{starting}}" hover-class="btn-hover">
        <text class="btn-icon">▶</text>
        <text>{{startButtonText}}</text>
      </button>
      <button class="primary-btn invite-btn" bindtap="inviteFriend" disabled="{{starting}}" hover-class="btn-hover">
        <text class="btn-icon">👤+</text>
        <text>邀请好友</text>
      </button>
      <button class="ready-btn" bindtap="toggleReady" disabled="{{starting}}" hover-class="btn-hover">
        <text class="btn-icon">{{selfReady ? '✓' : '○'}}</text>
        <text>{{selfReady ? '取消准备' : '准备'}}</text>
      </button>
    </view>

    <view class="bottom-nav">
      <view wx:for="{{ tabs }}" wx:key="key" class="nav-item {{ activeTab === item.key ? 'active' : '' }}" data-page="{{ item.page }}" bindtap="switchTab" hover-class="clickable-hover">
        <view class="nav-dot"><image class="nav-icon" src="{{activeTab===item.key ? item.iconActive : item.icon}}" mode="aspectFit"></image></view>
        <text>{{ item.label }}</text>
      </view>
    </view>
  </view>
</view>
