<view class="paper-bg result-page">
  <image class="global-bg-image" src="https://xcx.ukb88.com/assets/bg/bg.png" mode="scaleToFill"></image>

  <view class="app-header" style="padding-top: {{nav.statusBarHeight}}px; padding-right: {{nav.capsuleSpace}}px;">
    <view class="app-user" bindtap="onTapProfile" hover-class="clickable-hover">
      <image wx:if="{{userProfile.avatarUrl}}" class="app-user-avatar" src="{{userProfile.avatarUrl}}" mode="aspectFill"></image>
      <image wx:else class="app-user-avatar" src="{{defaultAvatar}}" mode="aspectFill"></image>
      <text class="app-user-name">{{userProfile.nickName}}</text>
    </view>
    <view class="app-header-right">
      <view class="app-status-pill">
        <text class="app-status-dot">●</text>
        <text class="app-status-text">{{modeText}}</text>
      </view>
      <view class="app-gear" hover-class="clickable-hover">⚙</view>
    </view>
  </view>

  <!-- 烟花特效容器 -->
  <view class="fireworks-container" wx:if="{{showFireworks}}">
    <view class="firework" wx:for="{{fireworkParticles}}" wx:key="id" style="left: {{item.left}}rpx; top: {{item.top}}rpx; animation-delay: {{item.delay}}ms;">
      <view class="firework-particle" wx:for="{{item.particles}}" wx:key="index" style="--angle: {{item.angle}}deg; --color: {{item.color}}; --size: {{item.size}}rpx; animation-delay: {{item.pDelay}}ms;"></view>
    </view>
  </view>

  <view class="page-content">
    <view class="main-title">获得胜利</view>
    <view class="sub-title">本局结算成绩</view>

    <view class="crown-mark">♛</view>
    <view class="podium-wrap">
      <view class="podium side left" bindtap="onTapPlayer" data-player="{{top3.second}}" hover-class="clickable-hover">
        <image class="podium-avatar" src="{{top3.second.avatar}}" mode="aspectFill"></image>
        <text class="podium-rank silver">2</text>
        <view class="podium-name">{{top3.second.name}}</view>
        <view class="podium-score">{{top3.second.score}}</view>
      </view>

      <view class="podium winner" bindtap="onTapPlayer" data-player="{{top3.first}}" hover-class="clickable-hover">
        <view class="winner-badge">♕</view>
        <image class="podium-avatar champion" src="{{top3.first.avatar}}" mode="aspectFill"></image>
        <text class="podium-rank gold">1</text>
        <view class="podium-name self">{{top3.first.name}}</view>
        <view class="podium-score self">{{top3.first.score}}</view>
      </view>

      <view class="podium side right" bindtap="onTapPlayer" data-player="{{top3.third}}" hover-class="clickable-hover">
        <image class="podium-avatar third" src="{{top3.third.avatar}}" mode="aspectFill"></image>
        <text class="podium-rank bronze">3</text>
        <view class="podium-name">{{top3.third.name}}</view>
        <view class="podium-score">{{top3.third.score}}</view>
      </view>
    </view>

    <view class="meta-row">
      <view class="card meta-card">
        <view class="meta-title">本局收益</view>
        <view class="income-main">{{incomeText}}</view>
        <view class="income-sub">已完成入账</view>
        <view class="exp-module">
          <view class="exp-head">
            <text>经验进度 Lv.{{expProgress.level}}</text>
            <text>+{{gainText}} EXP</text>
          </view>
          <view class="exp-track">
            <view class="exp-fill" style="width: {{expProgress.percent}}%;"></view>
          </view>
          <view class="exp-foot">{{expProgress.current}} / {{expProgress.required}} · 距下一级 {{expProgress.left}}</view>
        </view>
      </view>
      <view class="card meta-card">
        <view class="meta-title tag">新成就</view>
        <view class="meta-achievement">{{achievementText}}</view>
        <view class="meta-mountain"></view>
      </view>
    </view>

    <view class="rank-head">
      <view class="rank-title">详细排名 (4-10)</view>
      <view class="rank-total">{{totalText}}</view>
    </view>

    <view class="rank-list">
      <view class="rank-item" wx:for="{{rankList}}" wx:key="rank" bindtap="onTapPlayer" data-player="{{item}}" hover-class="clickable-hover">
        <text class="rank">{{item.rank}}</text>
        <image class="avatar sm" src="{{item.avatar}}" mode="aspectFill"></image>
        <text class="player">{{item.name}}</text>
        <text class="num">{{item.score}}</text>
      </view>
    </view>

    <view class="view-all" hover-class="clickable-hover">查看完整榜单</view>

    <view class="action-row">
      <button class="primary-btn action-btn" bindtap="replay" hover-class="btn-hover">↻ 再来一局</button>
      <button class="action-btn ghost-btn" bindtap="goHome" hover-class="btn-hover">⌂ 返回首页</button>
    </view>

    <view class="bottom-nav result-nav">
      <view wx:for="{{ tabs }}" wx:key="key" class="nav-item {{ activeTab === item.key ? 'active' : '' }}" data-page="{{ item.page }}" bindtap="switchTab" hover-class="clickable-hover">
        <view class="nav-dot">
          <image class="nav-icon" src="{{activeTab===item.key ? item.iconActive : item.icon}}" mode="aspectFit"></image>
        </view>
        <text>{{ item.label }}</text>
      </view>
    </view>

    <view class="nav-placeholder"></view>
  </view>

  <!-- 玩家分数明细弹窗 -->
  <view class="score-popup" wx:if="{{showScorePopup}}">
    <view class="score-popup-mask" bindtap="closeScorePopup"></view>
    <view class="score-popup-content">
      <view class="score-popup-close" bindtap="closeScorePopup">✕</view>
      <view class="score-popup-header">
        <image class="score-popup-avatar" src="{{selectedPlayer.avatar}}" mode="aspectFill"></image>
        <view class="score-popup-name">{{selectedPlayer.name}}</view>
        <view class="score-popup-total">总分 <text class="highlight">{{selectedPlayer.score}}</text></view>
      </view>
      <view class="score-popup-body">
        <view class="score-item">
          <text class="score-label">回合收益</text>
          <text class="score-value">{{scoreBreakdown.round}}</text>
        </view>
        <view class="score-item">
          <text class="score-label">团队联动</text>
          <text class="score-value">{{scoreBreakdown.teamBonus}}</text>
        </view>
        <view class="score-item">
          <text class="score-label">投资收益</text>
          <text class="score-value">{{scoreBreakdown.investment}}</text>
        </view>
        <view class="score-item">
          <text class="score-label">福袋事件</text>
          <text class="score-value">{{scoreBreakdown.fortuneBag}}</text>
        </view>
      </view>
      <view class="score-popup-divider"></view>
      <view class="score-popup-footer">
        数据结算完毕
      </view>
    </view>
  </view>
</view>
