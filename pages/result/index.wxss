.result-page {
  padding: 10rpx 24rpx 0;
  box-sizing: border-box;
}

.page-content {
  padding-bottom: 16rpx;
}

.main-title {
  margin-top: 10rpx;
  text-align: center;
  font-size: 76rpx;
  line-height: 1.04;
  color: #7b4314;
  font-weight: 900;
  letter-spacing: 1rpx;
  text-shadow: 0 5rpx 0 #f2debb, 0 10rpx 14rpx rgba(85, 35, 30, 0.22);
}

.sub-title {
  margin-top: 8rpx;
  text-align: center;
  color: #6f4b2a;
  font-size: 32rpx;
  font-weight: 700;
}

.crown-mark {
  margin-top: 14rpx;
  text-align: center;
  color: #d98a12;
  font-size: 42rpx;
  line-height: 1;
}

.podium-wrap {
  margin-top: 8rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 14rpx;
}

.podium {
  position: relative;
  text-align: center;
}

.podium-avatar {
  width: 82rpx;
  height: 82rpx;
  margin: 0 auto 10rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(232, 206, 154, 0.9);
  background: linear-gradient(145deg, #c4a47a, #8a6444);
  box-shadow: 0 10rpx 20rpx rgba(93, 67, 35, 0.2);
}

.podium-avatar.champion {
  width: 130rpx;
  height: 130rpx;
  border: 6rpx solid #f3b64f;
  box-shadow: 0 0 0 6rpx rgba(253, 223, 143, 0.24), 0 14rpx 24rpx rgba(93, 67, 35, 0.2);
}

.podium-avatar.third {
  background: linear-gradient(145deg, #b09070, #7a5d43);
}

.podium-rank {
  position: absolute;
  right: 10rpx;
  top: 48rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  line-height: 36rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.podium-rank.gold {
  top: 86rpx;
  right: 42rpx;
  background: #e57c1f;
}

.podium-rank.silver {
  background: #8f9fb3;
}

.podium-rank.bronze {
  background: #b45d2d;
}

.podium.side {
  width: 176rpx;
  border-radius: 108rpx 108rpx 0 0;
  background: rgba(255, 252, 244, 0.9);
  padding: 12rpx 14rpx 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(133, 98, 52, 0.14);
}

.podium.winner {
  width: 216rpx;
  min-height: 292rpx;
  border-radius: 24rpx;
  padding: 22rpx 16rpx 20rpx;
  background: linear-gradient(160deg, #f5bc60 0%, #e57c1f 60%, #c96a10 100%);
  border: 3rpx solid rgba(242, 189, 82, 0.78);
  box-shadow: 0 14rpx 30rpx rgba(146, 86, 20, 0.34), inset 0 2rpx 0 rgba(255, 235, 180, 0.22);
}

.winner-badge {
  position: absolute;
  top: -18rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 30rpx;
  color: #ffe09b;
}

.podium-name {
  color: #6b4a2d;
  font-size: 26rpx;
}

.podium-score {
  margin-top: 6rpx;
  color: #4f291c;
  font-size: 40rpx;
  font-weight: 800;
}

.podium-name.self {
  color: #57181b;
  font-weight: 700;
}

.podium-score.self {
  margin-top: 10rpx;
  color: #fff5e8;
  font-size: 56rpx;
  text-shadow: 0 4rpx 12rpx rgba(83, 28, 36, 0.22);
}

.settlement-panel {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: 166rpx 1fr;
  gap: 14rpx 18rpx;
  align-items: center;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 240, 0.94);
  box-shadow: 0 10rpx 24rpx rgba(133, 98, 52, 0.13);
}

.income-block {
  min-width: 0;
  border-right: 2rpx solid rgba(213, 183, 134, 0.32);
}

.meta-title {
  color: #7d5b3a;
  font-size: 24rpx;
  font-weight: 700;
}

.income-main {
  margin-top: 6rpx;
  color: #e57c1f;
  font-size: 54rpx;
  font-weight: 900;
  line-height: 1.05;
}

.exp-module {
  min-width: 0;
}

.exp-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  color: #6d4a29;
  font-size: 24rpx;
  font-weight: 600;
}

.exp-head text {
  white-space: nowrap;
}

.exp-track {
  margin-top: 8rpx;
  width: 100%;
  height: 16rpx;
  border-radius: 999rpx;
  padding: 2rpx;
  box-sizing: border-box;
  background: rgba(213, 183, 134, 0.34);
}

.exp-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f4b24a, #e57c1f);
}

.exp-foot {
  margin-top: 6rpx;
  color: #8f6d45;
  font-size: 22rpx;
  line-height: 1;
}

.achievement-pill {
  grid-column: 1 / 3;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(213, 183, 134, 0.24);
}

.achievement-medal {
  position: relative;
  flex: none;
  width: 86rpx;
  height: 100rpx;
}

.medal-ribbon {
  position: absolute;
  left: 23rpx;
  top: 56rpx;
  width: 20rpx;
  height: 42rpx;
  background: linear-gradient(180deg, var(--medal-accent, #c86f18), #8d4717);
  transform: rotate(14deg);
  transform-origin: top center;
  clip-path: polygon(0 0, 100% 0, 80% 100%, 50% 78%, 20% 100%);
}

.medal-ribbon.right {
  left: 43rpx;
  transform: rotate(-14deg);
}

.medal-core {
  position: absolute;
  left: 7rpx;
  top: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 6rpx solid var(--medal-rim, #f5b744);
  box-sizing: border-box;
  background: radial-gradient(circle at 35% 28%, #fffaf0 0%, var(--medal-plate, #fff3c8) 48%, var(--medal-glow, #f1b24b) 100%);
  box-shadow: 0 8rpx 18rpx rgba(117, 71, 26, 0.2), inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.medal-core::before {
  content: '';
  position: absolute;
  inset: 8rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(125, 91, 58, 0.22);
}

.medal-symbol {
  position: relative;
  z-index: 1;
  text-align: center;
  line-height: 60rpx;
  color: var(--medal-accent, #c86f18);
  font-size: 34rpx;
  font-weight: 900;
}

.achievement-copy {
  flex: 1;
  min-width: 0;
}

.achievement-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.achievement-label {
  flex: none;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #ead8bc;
  color: #7d5b3a;
  font-size: 22rpx;
  font-weight: 700;
}

.medal-tier {
  min-width: 0;
  color: #9a7146;
  font-size: 22rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.achievement-name {
  display: block;
  min-width: 0;
  margin-top: 8rpx;
  color: #4d2c1b;
  font-size: 32rpx;
  line-height: 1.15;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-head {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rank-title {
  color: #6b4a2d;
  font-size: 30rpx;
  font-weight: 700;
}

.rank-total {
  color: #997955;
  font-size: 24rpx;
}

.rank-list {
  margin-top: 8rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  margin-bottom: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.93);
  box-shadow: 0 10rpx 24rpx rgba(133, 98, 52, 0.14);
}

.rank-item .rank {
  width: 34rpx;
  color: #6e4d30;
  font-size: 34rpx;
  font-weight: 700;
}

.avatar.sm {
  width: 48rpx;
  height: 48rpx;
  margin: 0 14rpx 0 12rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #c4a47a, #8a6444);
}

.player {
  flex: 1;
  color: #4e2e1f;
  font-size: 32rpx;
  font-weight: 600;
}

.num {
  color: #4f291d;
  font-size: 36rpx;
  font-weight: 800;
}

.action-row {
  margin-top: 18rpx;
  display: flex;
  gap: 14rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border: 0;
  border-radius: 999rpx;
  padding: 0;
  font-size: 30rpx;
  font-weight: 700;
}

.action-btn::after {
  border: none;
}

.ghost-btn {
  background: rgba(242, 227, 198, 0.95);
  color: #5e4228;
  border: 2rpx solid rgba(214, 186, 138, 0.75);
}

.result-nav {
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 28rpx 28rpx 0 0;
}

.nav-placeholder {
  height: 156rpx;
}

/* 玩家分数明细弹窗 */
.score-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(43, 26, 17, 0.65);
  backdrop-filter: blur(8rpx);
}

.score-popup-content {
  position: relative;
  width: 600rpx;
  background: linear-gradient(135deg, #fefbfa 0%, #f6ecd8 100%);
  border-radius: 36rpx;
  box-shadow: 0 20rpx 40rpx rgba(85, 35, 30, 0.4), inset 0 4rpx 10rpx rgba(255, 255, 255, 0.8);
  border: 4rpx solid rgba(220, 196, 154, 0.8);
  padding: 40rpx 40rpx 30rpx;
  box-sizing: border-box;
  animation: popup-scale 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

@keyframes popup-scale {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.score-popup-close {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 50rpx;
  height: 50rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 32rpx;
  color: #a88b69;
  background: rgba(234, 216, 185, 0.5);
  border-radius: 50%;
  font-weight: bold;
}

.score-popup-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.score-popup-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #e2c18d;
  box-shadow: 0 8rpx 16rpx rgba(110, 74, 43, 0.2);
  margin-bottom: 16rpx;
}

.score-popup-name {
  font-size: 36rpx;
  color: #4e2e1f;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.score-popup-total {
  font-size: 28rpx;
  color: #7d5b3a;
  font-weight: 600;
  background: rgba(226, 193, 141, 0.3);
  padding: 6rpx 24rpx;
  border-radius: 999rpx;
}

.score-popup-total .highlight {
  font-size: 36rpx;
  color: #e57c1f;
  font-weight: 900;
  margin-left: 8rpx;
}

.score-popup-body {
  background: rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  border: 2rpx dashed rgba(186, 151, 107, 0.4);
}

.score-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 10rpx;
  border-bottom: 2rpx solid rgba(220, 196, 154, 0.3);
}

.score-item:last-child {
  border-bottom: none;
}

.score-label {
  font-size: 30rpx;
  color: #6b4a2d;
  font-weight: 600;
}

.score-value {
  font-size: 32rpx;
  color: #4e2e1f;
  font-weight: 700;
}

.score-value.bonus {
  color: #e57c1f;
}

.score-value.penalty {
  color: #517150;
}

.score-popup-divider {
  width: 100%;
  height: 2rpx;
  background: linear-gradient(to right, rgba(226, 193, 141, 0), rgba(226, 193, 141, 1), rgba(226, 193, 141, 0));
  margin: 30rpx 0 20rpx;
}

.score-popup-footer {
  text-align: center;
  font-size: 24rpx;
  color: #a88b69;
  letter-spacing: 2rpx;
}

/* 烟花特效样式 */
.fireworks-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 100;
  overflow: hidden;
}

.firework {
  position: absolute;
  width: 0;
  height: 0;
}

.firework-particle {
  position: absolute;
  width: var(--size);
  height: var(--size);
  background: var(--color);
  border-radius: 50%;
  box-shadow: 0 0 10rpx var(--color), 0 0 20rpx var(--color);
  animation: firework-burst 1.2s ease-out forwards;
  transform: rotate(var(--angle)) translateX(0);
  opacity: 1;
}

@keyframes firework-burst {
  0% {
    transform: rotate(var(--angle)) translateX(0) scale(1);
    opacity: 1;
  }
  50% {
    opacity: 0.8;
  }
  100% {
    transform: rotate(var(--angle)) translateX(200rpx) scale(0);
    opacity: 0;
  }
}

/* 额外的闪光效果 */
.firework::before {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: white;
  border-radius: 50%;
  box-shadow: 0 0 20rpx white, 0 0 40rpx white;
  animation: firework-flash 0.3s ease-out forwards;
}

@keyframes firework-flash {
  0% {
    transform: scale(0);
    opacity: 1;
  }
  50% {
    transform: scale(3);
    opacity: 0.8;
  }
  100% {
    transform: scale(0);
    opacity: 0;
  }
}
