.result-page {
  padding: 10rpx 24rpx 0;
  box-sizing: border-box;
}

.page-content {
  padding-bottom: 16rpx;
}

.main-title {
  margin-top: 10rpx;
  text-align: center;
  font-size: 76rpx;
  line-height: 1.04;
  color: #581f1c;
  font-weight: 900;
  letter-spacing: 1rpx;
  text-shadow: 0 5rpx 0 #f2debb, 0 10rpx 14rpx rgba(85, 35, 30, 0.22);
}

.sub-title {
  margin-top: 8rpx;
  text-align: center;
  color: #6f4b2a;
  font-size: 32rpx;
  font-weight: 700;
}

.crown-mark {
  margin-top: 14rpx;
  text-align: center;
  color: #d7a019;
  font-size: 42rpx;
  line-height: 1;
}

.podium-wrap {
  margin-top: 8rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 14rpx;
}

.podium {
  position: relative;
  text-align: center;
}

.podium-avatar {
  width: 82rpx;
  height: 82rpx;
  margin: 0 auto 10rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(232, 206, 154, 0.9);
  background: linear-gradient(145deg, #495f7c, #1f3247);
  box-shadow: 0 10rpx 20rpx rgba(93, 67, 35, 0.2);
}

.podium-avatar.champion {
  width: 130rpx;
  height: 130rpx;
  border: 6rpx solid #f2c453;
  box-shadow: 0 0 0 6rpx rgba(253, 223, 143, 0.24), 0 14rpx 24rpx rgba(93, 67, 35, 0.2);
}

.podium-avatar.third {
  background: linear-gradient(145deg, #4d6178, #293b4f);
}

.podium-rank {
  position: absolute;
  right: 10rpx;
  top: 48rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  line-height: 36rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.podium-rank.gold {
  top: 86rpx;
  right: 42rpx;
  background: #f8bc12;
}

.podium-rank.silver {
  background: #8f9fb3;
}

.podium-rank.bronze {
  background: #b45d2d;
}

.podium.side {
  width: 176rpx;
  border-radius: 108rpx 108rpx 0 0;
  background: rgba(255, 252, 244, 0.9);
  padding: 12rpx 14rpx 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(133, 98, 52, 0.14);
}

.podium.winner {
  width: 216rpx;
  min-height: 292rpx;
  border-radius: 24rpx;
  padding: 22rpx 16rpx 20rpx;
  background: linear-gradient(180deg, #ff8a91 0%, #f84b63 58%, #e6314c 100%);
  border: 3rpx solid rgba(255, 200, 117, 0.88);
  box-shadow: 0 14rpx 30rpx rgba(171, 44, 54, 0.34);
}

.winner-badge {
  position: absolute;
  top: -18rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 30rpx;
  color: #f5c34a;
}

.podium-name {
  color: #6b4a2d;
  font-size: 26rpx;
}

.podium-score {
  margin-top: 6rpx;
  color: #4f291c;
  font-size: 40rpx;
  font-weight: 800;
}

.podium-name.self {
  color: #57181b;
  font-weight: 700;
}

.podium-score.self {
  margin-top: 10rpx;
  color: #fff5e8;
  font-size: 56rpx;
  text-shadow: 0 4rpx 12rpx rgba(83, 28, 36, 0.22);
}

.meta-row {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
}

.meta-card {
  flex: 1;
  min-height: 196rpx;
  padding: 18rpx 18rpx 14rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 240, 0.92);
}

.meta-title {
  color: #7d5b3a;
  font-size: 30rpx;
  font-weight: 700;
}

.meta-title.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #ead8bc;
  font-size: 24rpx;
}

.meta-line {
  margin-top: 12rpx;
  color: #5e321f;
  font-size: 48rpx;
  font-weight: 800;
}

.meta-line.gain::before {
  content: "✹ ";
  font-size: 24rpx;
  color: #dc6d5e;
}

.meta-label {
  font-size: 28rpx;
  color: #6e4a2b;
  font-weight: 600;
}

.meta-line.coin::before {
  content: "◉ ";
  font-size: 28rpx;
  color: #d59a22;
}

.meta-achievement {
  margin-top: 12rpx;
  color: #4d2c1b;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 800;
}

.meta-mountain {
  width: 100%;
  height: 44rpx;
  margin-top: 18rpx;
  border-radius: 10rpx;
  background: linear-gradient(145deg, rgba(220, 201, 168, 0.95), rgba(174, 143, 104, 0.9));
  clip-path: polygon(0 100%, 24% 42%, 54% 100%, 74% 58%, 100% 100%);
}

.rank-head {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rank-title {
  color: #6b4a2d;
  font-size: 32rpx;
  font-weight: 700;
}

.rank-total {
  color: #997955;
  font-size: 24rpx;
}

.rank-list {
  margin-top: 10rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  margin-bottom: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.93);
  box-shadow: 0 10rpx 24rpx rgba(133, 98, 52, 0.14);
}

.rank-item .rank {
  width: 34rpx;
  color: #6e4d30;
  font-size: 34rpx;
  font-weight: 700;
}

.avatar.sm {
  width: 48rpx;
  height: 48rpx;
  margin: 0 14rpx 0 12rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #4b6780, #1e3448);
}

.player {
  flex: 1;
  color: #4e2e1f;
  font-size: 32rpx;
  font-weight: 600;
}

.num {
  color: #4f291d;
  font-size: 36rpx;
  font-weight: 800;
}

.view-all {
  margin-top: 4rpx;
  text-align: center;
  color: #9e7f57;
  font-size: 24rpx;
}

.action-row {
  margin-top: 22rpx;
  display: flex;
  gap: 14rpx;
}

.action-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border: 0;
  border-radius: 999rpx;
  padding: 0;
  font-size: 30rpx;
  font-weight: 700;
}

.action-btn::after {
  border: none;
}

.ghost-btn {
  background: rgba(242, 227, 198, 0.95);
  color: #5e4228;
  border: 2rpx solid rgba(214, 186, 138, 0.75);
}

.result-nav {
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 28rpx 28rpx 0 0;
}

.nav-placeholder {
  height: 156rpx;
}
