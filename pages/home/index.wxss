.home-page {
  padding: 16rpx 22rpx 180rpx;
}

.topbar-spacer {
  box-sizing: border-box;
}

.hero-safe {
  box-sizing: border-box;
  width: 100%;
}

.hero-title {
  margin-top: 4rpx;
  color: #e57c1f;
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 0;
  text-shadow: 0 2rpx 0 rgba(181, 102, 19, 0.16);
}

.subtitle {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #443a33;
  line-height: 1.45;
  font-weight: 600;
}

.profile-card {
  margin-top: 18rpx;
  padding: 28rpx 30rpx 24rpx;
  border-radius: 36rpx;
  background: rgba(243, 228, 197, 0.96);
  border: 2rpx solid rgba(214, 186, 138, 0.42);
  box-shadow: 0 12rpx 24rpx rgba(123, 87, 41, 0.14);
}

.profile-copy {
  display: flex;
  flex-direction: column;
}

.minor {
  font-size: 22rpx;
  color: #977650;
  letter-spacing: 1rpx;
}

.title-row {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.name {
  font-size: 44rpx;
  font-weight: 800;
  color: #3a281a;
  line-height: 1.08;
}

.badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(232, 210, 167, 0.78);
  border: 2rpx solid rgba(206, 171, 113, 0.2);
  color: #93683a;
  font-size: 22rpx;
  font-weight: 600;
}

.profile-meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #856642;
  line-height: 1.4;
}

.profile-divider {
  margin: 20rpx 0 18rpx;
  height: 2rpx;
  background: rgba(206, 177, 132, 0.42);
}

.account-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.account-copy {
  min-width: 0;
}

.clickable {
  padding: 0;
  border-radius: 0;
  background: transparent;
}

.label {
  font-size: 24rpx;
  color: #9c7a4f;
}

.value {
  margin-top: 10rpx;
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.05;
}

.gold {
  color: #d97712;
}

.jump-hint {
  flex-shrink: 0;
  margin-bottom: 8rpx;
  color: #9f7d56;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.exp-progress {
  margin-top: 16rpx;
}

.exp-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(214, 186, 138, 0.34);
  overflow: hidden;
}

.exp-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f5bc60, #eb9230 58%, #e57c1f);
}

.section-head {
  margin: 26rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 26rpx;
  color: #8d6940;
}

.section-tip {
  font-size: 22rpx;
  color: #ae8f68;
}

.destination-card {
  padding: 8rpx 0 8rpx 8rpx;
  border: 3rpx solid #d7bb8a;
  border-radius: 34rpx;
  overflow: hidden;
  background: transparent;
}

.stage-swiper {
  height: 860rpx;
}

.stage-item {
  position: relative;
  height: 100%;
  margin-right: 10rpx;
  border: 3rpx solid #cfb183;
  border-radius: 34rpx;
  overflow: hidden;
  box-sizing: border-box;
  background: #f6edd8;
}

.tag {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  z-index: 2;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e78a20;
  color: #fff6ea;
  font-size: 20rpx;
}

.stage-image {
  width: 100%;
  height: 100%;
  display: block;
}

.stage-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 140rpx 42rpx 38rpx;
  background: linear-gradient(180deg, rgba(246, 237, 216, 0) 0%, rgba(246, 237, 216, 0.78) 34%, rgba(246, 237, 216, 0.98) 62%, rgba(246, 237, 216, 1) 100%);
}

.dest-meta {
  font-size: 20rpx;
  color: #e08a18;
  letter-spacing: 4rpx;
}

.dest-name {
  margin-top: 6rpx;
  font-size: 78rpx;
  color: #c76d11;
  font-weight: 900;
  line-height: 1.08;
}

.dest-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8e6945;
}

.start-btn {
  margin-top: 28rpx;
  height: 88rpx;
  font-size: 32rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-btn::after {
  border: none;
}
