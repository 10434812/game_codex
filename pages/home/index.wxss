.home-page {
  padding: 16rpx 22rpx 330rpx;
}

.home-page .page-content {
  padding-bottom: 260rpx;
}

.topbar-spacer {
  box-sizing: border-box;
}

.hero-safe {
  box-sizing: border-box;
  width: 100%;
}

.hero-title {
  margin-top: 4rpx;
  color: #dc7419;
  font-family: "Songti SC", "STSong", "Kaiti SC", "KaiTi", serif;
  font-size: 76rpx;
  font-weight: 900;
  line-height: 1.02;
  letter-spacing: 3rpx;
  -webkit-text-stroke: 1rpx rgba(143, 76, 15, 0.12);
  text-shadow:
    0 3rpx 0 rgba(255, 239, 199, 0.86),
    0 10rpx 18rpx rgba(166, 88, 15, 0.16);
  animation: title-ink-rise 0.68s cubic-bezier(0.16, 1, 0.3, 1) both, title-luck-glow 3.4s ease-in-out 0.8s infinite;
}

.hero-copy {
  margin-top: 18rpx;
}

.subtitle {
  position: relative;
  max-width: 690rpx;
  color: #4a3828;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.35;
  letter-spacing: 0;
  white-space: nowrap;
  animation: soft-slide-up 0.54s ease-out 0.12s both;
}

.profile-card {
  margin-top: 18rpx;
  padding: 28rpx 30rpx 24rpx;
  border-radius: 36rpx;
  background: rgba(243, 228, 197, 0.96);
  border: 2rpx solid rgba(214, 186, 138, 0.42);
  box-shadow: 0 12rpx 24rpx rgba(123, 87, 41, 0.14);
  animation: soft-slide-up 0.42s ease-out both;
}

.profile-copy {
  display: flex;
  flex-direction: column;
}

.minor {
  font-size: 22rpx;
  color: #977650;
  letter-spacing: 1rpx;
}

.title-row {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.name {
  font-size: 44rpx;
  font-weight: 800;
  color: #3a281a;
  line-height: 1.08;
}

.badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(232, 210, 167, 0.78);
  border: 2rpx solid rgba(206, 171, 113, 0.2);
  color: #93683a;
  font-size: 22rpx;
  font-weight: 600;
}

.profile-meta {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #856642;
  line-height: 1.4;
}

.profile-divider {
  margin: 20rpx 0 18rpx;
  height: 2rpx;
  background: rgba(206, 177, 132, 0.42);
}

.account-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.account-copy {
  min-width: 0;
}

.clickable {
  padding: 0;
  border-radius: 0;
  background: transparent;
}

.label {
  font-size: 24rpx;
  color: #9c7a4f;
}

.value {
  margin-top: 4rpx;
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.05;
}

.gold {
  color: #d97712;
}

.jump-hint {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  color: #93683a;
  background: rgba(232, 210, 167, 0.78);
  border: 2rpx solid rgba(206, 171, 113, 0.2);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.exp-progress {
  margin-top: 16rpx;
}

.exp-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(214, 186, 138, 0.34);
  overflow: hidden;
}

.exp-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #f5bc60, #eb9230 58%, #e57c1f);
  box-shadow: 0 0 14rpx rgba(229, 124, 31, 0.28);
  transition: width 0.45s ease;
}

.profile-card-wrap {
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.profile-card-wrap.expanded {
  max-height: 600rpx;
}

.expand-toggle {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  color: #9c7a4f;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border-radius: 999rpx;
  background: rgba(156, 122, 79, 0.06);
  border: 2rpx solid rgba(156, 122, 79, 0.12);
  animation: soft-slide-up 0.48s ease-out 0.18s both;
}

.section-head {
  margin: 26rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  animation: soft-slide-up 0.48s ease-out 0.26s both;
}

.section-title {
  font-size: 26rpx;
  color: #8d6940;
}

.section-tip {
  font-size: 22rpx;
  color: #ae8f68;
}

.destination-card {
  padding: 8rpx 0 8rpx 8rpx;
  border: 3rpx solid #d7bb8a;
  border-radius: 34rpx;
  overflow: hidden;
  background: transparent;
  animation: card-float-in 0.62s cubic-bezier(0.16, 1, 0.3, 1) 0.32s both;
}

.stage-swiper {
  height: 860rpx;
}

.stage-item {
  position: relative;
  height: 100%;
  margin-right: 10rpx;
  border: 3rpx solid #cfb183;
  border-radius: 34rpx;
  overflow: hidden;
  box-sizing: border-box;
  background: #f6edd8;
  transform: translateZ(0);
}

.tag {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  z-index: 2;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #e78a20;
  color: #fff6ea;
  font-size: 20rpx;
  animation: tag-pop 0.42s ease-out 0.62s both;
}

.stage-image {
  width: 100%;
  height: 100%;
  display: block;
  transform: scale(1.02);
  animation: stage-drift 9s ease-in-out infinite alternate;
}

.stage-info {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 140rpx 42rpx 38rpx;
  background: linear-gradient(180deg, rgba(246, 237, 216, 0) 0%, rgba(246, 237, 216, 0.78) 34%, rgba(246, 237, 216, 0.98) 62%, rgba(246, 237, 216, 1) 100%);
  animation: soft-slide-up 0.56s ease-out 0.48s both;
}

.dest-meta {
  font-size: 20rpx;
  color: var(--stage-accent-color, #e08a18);
  letter-spacing: 4rpx;
}

.dest-name {
  margin-top: 6rpx;
  font-size: 48rpx;
  color: var(--stage-title-color, #c76d11);
  font-weight: 900;
  line-height: 1.12;
}

.dest-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8e6945;
}

.start-btn {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  bottom: 166rpx;
  z-index: 18;
  margin: 0;
  height: 88rpx;
  font-size: 32rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  animation: btn-breathe 2s infinite ease-in-out;
  box-shadow: 0 8rpx 20rpx rgba(229, 124, 31, 0.4);
}

.home-page .bottom-nav {
  z-index: 20;
}

.start-btn::before {
  content: '';
  position: absolute;
  left: -30%;
  top: 0;
  width: 28%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.42), transparent);
  transform: skewX(-18deg);
  animation: btn-sheen 2.8s ease-in-out infinite;
}

@keyframes btn-breathe {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 8rpx 20rpx rgba(229, 124, 31, 0.4);
  }
  50% {
    transform: scale(1.03);
    box-shadow: 0 12rpx 28rpx rgba(229, 124, 31, 0.6);
  }
}

.start-btn::after {
  border: none;
}

@keyframes title-ink-rise {
  from {
    opacity: 0;
    transform: translateY(24rpx) scale(0.96);
    filter: blur(2rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }
}

@keyframes title-luck-glow {
  0%, 100% {
    text-shadow:
      0 3rpx 0 rgba(255, 239, 199, 0.86),
      0 10rpx 18rpx rgba(166, 88, 15, 0.16);
  }
  50% {
    text-shadow:
      0 3rpx 0 rgba(255, 239, 199, 0.96),
      0 14rpx 26rpx rgba(224, 124, 29, 0.32);
  }
}

@keyframes soft-slide-up {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes card-float-in {
  from {
    opacity: 0;
    transform: translateY(34rpx) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes tag-pop {
  from {
    opacity: 0;
    transform: translateY(-10rpx) scale(0.82);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes stage-drift {
  from {
    transform: scale(1.02) translate3d(-8rpx, 0, 0);
  }
  to {
    transform: scale(1.07) translate3d(10rpx, -8rpx, 0);
  }
}

@keyframes btn-sheen {
  0%, 45% {
    left: -34%;
    opacity: 0;
  }
  58% {
    opacity: 1;
  }
  100% {
    left: 108%;
    opacity: 0;
  }
}
