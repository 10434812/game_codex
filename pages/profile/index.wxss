.profile-page {
  min-height: 100vh;
  padding: 16rpx 24rpx 36rpx;
  box-sizing: border-box;
}

.profile-header {
  margin-bottom: 12rpx;
}

.profile-content {
  display: flex;
  justify-content: center;
}

.profile-card {
  margin-top: 18rpx;
  width: 100%;
  max-width: 690rpx;
  padding: 44rpx 34rpx 38rpx;
  border-radius: 34rpx;
  box-sizing: border-box;
}

.avatar-section {
  width: 100%;
  display: grid;
  justify-items: center;
  row-gap: 16rpx;
}

.avatar-picker {
  width: 180rpx;
  height: 180rpx;
  padding: 0;
  border: 0;
  background: transparent;
  margin: 0 !important;
  display: flex;
  align-items: center;
  justify-content: center;
  justify-self: center;
}

.avatar-picker::after {
  border: 0;
}

.picked-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 4rpx solid #c7a16b;
  background: #f8ebcf;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a17844;
  font-size: 70rpx;
  box-sizing: border-box;
}

.picked-avatar.empty {
  font-size: 78rpx;
  line-height: 1;
}

.helper {
  width: 100%;
  text-align: center;
  color: #94724a;
  font-size: 25rpx;
  line-height: 1.3;
}

.form-section {
  margin: 30rpx auto 0;
  width: 100%;
  max-width: 600rpx;
}

.nickname-input {
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 18rpx;
  border: 2rpx solid #d4b383;
  padding: 0 22rpx;
  color: #4f321b;
  font-size: 30rpx;
  background: rgba(255, 249, 236, 0.92);
  box-sizing: border-box;
}

.save-btn {
  margin-top: 26rpx;
  width: 100%;
  height: 88rpx;
  line-height: normal;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-weight: 700;
}

.save-btn[disabled] {
  opacity: 0.55;
  color: rgba(255, 245, 229, 0.88);
}
